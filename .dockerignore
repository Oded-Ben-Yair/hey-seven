# .dockerignore — minimize Docker context and image size
# Only src/, data/, static/, and requirements-prod.txt are needed in the image.

# Version control
.git
.gitignore
.github

# Python
.venv
venv
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.ruff_cache
htmlcov
.coverage
dist
build

# Development & test
.env
.env.*
!.env.example
tests/
scripts/
requirements-dev.txt
reviews/
deliverables/
research/
knowledge-base/
boilerplate/
assignment/

# Documentation (not needed in image)
docs/
*.md
!README.md
!ARCHITECTURE.md

# Claude Code session data (R41 fix D6-M004)
.claude/
.hypothesis/

# IDE
.vscode
.idea
*.swp

# Docker meta (avoid recursive copy)
Dockerfile
docker-compose.yml
.dockerignore

# Data (rebuilt at startup via lifespan)
data/chroma/
